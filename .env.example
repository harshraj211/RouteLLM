ROUTELLM_ENVIRONMENT=development
ROUTELLM_API_PREFIX=/v1
ROUTELLM_DATABASE_URL=sqlite:///./routellm.db
ROUTELLM_REDIS_URL=redis://localhost:6379/0
ROUTELLM_ENABLE_DOCS=true
# Use mock for deterministic local development; switch to live for real provider calls.
ROUTELLM_INFERENCE_MODE=mock
ROUTELLM_INFERENCE_TIMEOUT_SECONDS=30
ROUTELLM_INFERENCE_MAX_RETRIES=1
ROUTELLM_INFERENCE_RETRY_BACKOFF_SECONDS=0.1
ROUTELLM_CHAT_DEFAULT_TENANT_ID=default
ROUTELLM_CHAT_DEFAULT_WORKFLOW_ID=chat-completions
ROUTELLM_CHAT_DEFAULT_TASK_TYPE=qa
ROUTELLM_CHAT_DEFAULT_MAX_BUDGET_USD=0.05
ROUTELLM_CHAT_DEFAULT_LATENCY_SLO_MS=30000
ROUTELLM_MODEL_REGISTRY_PATH=config/models.yaml
ROUTELLM_MODEL_REGISTRY_WRITES_ENABLED=true
ROUTELLM_LOCAL_SMALL_BASE_URL=http://localhost:8001/v1
ROUTELLM_LOCAL_SMALL_MODEL=local-small
ROUTELLM_LOCAL_MEDIUM_BASE_URL=http://localhost:8002/v1
ROUTELLM_LOCAL_MEDIUM_MODEL=local-medium-json
ROUTELLM_HOSTED_BASE_URL=https://api.openai.com/v1
ROUTELLM_HOSTED_MODEL=gpt-5-mini
ROUTELLM_HOSTED_API_KEY_ENV=OPENAI_API_KEY
# OPENAI_API_KEY=replace-me
# GEMINI_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me
# XAI_API_KEY=replace-me
ROUTELLM_OTEL_ENABLED=false
ROUTELLM_OTEL_SERVICE_NAME=routellm-api
ROUTELLM_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

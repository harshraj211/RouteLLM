ROUTELLM_ENVIRONMENT=development
ROUTELLM_API_PREFIX=/v1
ROUTELLM_DATABASE_URL=sqlite:///./routellm.db
ROUTELLM_REDIS_URL=redis://localhost:6379/0
ROUTELLM_ENABLE_DOCS=true
ROUTELLM_OTEL_ENABLED=false
ROUTELLM_OTEL_SERVICE_NAME=routellm-api
ROUTELLM_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
